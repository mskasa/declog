#!/bin/sh
# Added by kizami — https://github.com/mskasa/kizami
# Warns when a commit contains no ADR in docs/decisions/.

# Skip if ADR files are included in this commit.
if git diff --cached --name-only | grep -q "^docs/decisions/"; then
  exit 0
fi

# Skip if this is a documentation-only commit (only .md files changed).
if git diff --cached --name-only | grep -qvE "\.md$"; then
  : # has non-md files — fall through to warning
else
  exit 0
fi

printf "\n⚠️  No ADR found in this commit.\n"
printf "    If this change involves a significant design decision,\n"
printf "    consider running: kizami adr \"<title>\"\n\n"
